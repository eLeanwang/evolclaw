{
  "name": "evolclaw",
  "version": "2.0.7",
  "description": "Lightweight AI Agent gateway connecting Claude Agent SDK to messaging channels (Feishu, ACP) with multi-project session management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "evolclaw": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "!dist/experimental/",
    "data/evolclaw.sample.json"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"const f='dist/cli.js',c=require('fs').readFileSync(f,'utf8');if(!c.startsWith('#!'))require('fs').writeFileSync(f,'#!/usr/bin/env node\\n'+c)\" && node -e \"try{require('child_process').execFileSync('chmod',['+x','dist/cli.js'])}catch{}\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:hooks": "tsx test-sdk-hooks.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.75",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "image-type": "^6.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
